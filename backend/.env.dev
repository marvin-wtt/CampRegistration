# Storage
# File encryption at rest: `keyId:base64Key[,olderKeyId:base64Key]`, first key
# Key schema: kYYYYMMDD-NN (e.g. k20260101-01).
# encrypts new files. Generate a key with `openssl rand -base64 32`.
STORAGE_ENCRYPTION_KEYS=k20260713-01:nuEkGZ0WePsfS0jdcXwXjyl7ArdOABkEQoXOdgDWUQk=

# Queue
QUEUE_DRIVER=database

# SMTP configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USERNAME=user
SMTP_PASSWORD=password

# Email configuration
EMAIL_FROM=noreply@yourapp.com
EMAIL_REPLY_TO=reply-to@yourapp.com
EMAIL_ADMIN=admin@yourapp.com

# Translation
# Auto-translate provider for translated input fields. Unset (default) hides
# the auto-translate feature in the UI. Set to "azure", "deepl" or "google"
# and provide the matching key(s) below to enable it.
#TRANSLATION_DRIVER=
# AZURE_TRANSLATOR_KEY=
# AZURE_TRANSLATOR_REGION=
# DEEPL_API_KEY=
# GOOGLE_TRANSLATE_API_KEY=
