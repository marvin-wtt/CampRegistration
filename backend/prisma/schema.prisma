generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// TODO This is a workaround due to https://github.com/prisma/prisma/issues/3219
generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "mysql"
}

model User {
  id               String    @id @unique(map: "users_id_unique") @default(ulid()) @db.Char(26)
  name             String    @db.VarChar(255)
  email            String    @unique(map: "users_email_unique") @db.VarChar(255)
  emailVerified    Boolean   @default(false) @map("email_verified")
  password         String    @db.VarChar(255)
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  totpSecret       String?   @map("totp_secret") @db.Char(32)
  role             Role      @default(USER)
  locale           String    @default("en-US") @db.VarChar(5)
  locked           Boolean   @default(false)
  lastSeen         DateTime? @map("last_seen")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  campRoles              CampManager[]
  tokens                 Token[]
  newsletterManagers     NewsletterManager[]
  sentNewsletterMessages NewsletterMessage[]
  sentMessages           Message[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

enum ConfirmationMode {
  AUTOMATIC
  MANUAL
}

model Camp {
  id                   String           @id @unique(map: "camps_id_unique") @default(ulid()) @db.Char(26)
  public               Boolean
  registrationOpensAt  DateTime?        @map("registration_opens_at") @db.DateTime(0)
  registrationClosesAt DateTime?        @map("registration_closes_at") @db.DateTime(0)
  confirmationMode     ConfirmationMode @default(AUTOMATIC) @map("confirmation_mode")
  /// ![Array<string>]
  countries            Json             @db.Json
  /// ![string | Record<string, string>]
  name                 Json             @db.Json
  /// ![string | Record<string, string>]
  organizer            Json             @db.Json
  /// ![string | Record<string, string>]
  contactEmail         Json             @map("contact_email") @db.Json
  /// ![number | Record<string, number>]
  maxParticipants      Json             @map("max_participants") @db.Json
  minAge               Int              @map("min_age") @db.UnsignedInt
  maxAge               Int              @map("max_age") @db.UnsignedInt
  startAt              DateTime         @map("start_at") @db.DateTime(0)
  endAt                DateTime         @map("end_at") @db.DateTime(0)
  price                Float
  /// ![string | Record<string, string>]
  location             Json?            @db.Json
  /// ![Record<string, unknown>]
  form                 Json             @db.Json
  /// ![Record<string, unknown>]
  themes               Json             @default("{}") @db.Json
  createdAt            DateTime?        @default(now()) @map("created_at")
  updatedAt            DateTime?        @updatedAt @map("updated_at")

  campManager      CampManager[]
  registrations    Registration[]
  rooms            Room[]
  tableTemplates   TableTemplate[]
  messageTemplates MessageTemplate[]
  messages         Message[]
  files            File[]
  programEvents    ProgramEvent[]
  auditLogs        AuditLog[]

  @@map("camps")
}

model CampManager {
  id           String    @id @unique(map: "camp_managers_id_unique") @default(ulid()) @db.Char(26)
  campId       String    @map("camp_id") @db.Char(26)
  userId       String?   @map("user_id") @db.Char(26)
  role         String    @db.VarChar(50)
  invitationId String?   @map("invitation_id") @db.Char(26)
  expiresAt    DateTime? @map("expires_at") @db.DateTime(0)

  camp       Camp        @relation(fields: [campId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "camp_managers_camp_id_foreign")
  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "camp_managers_user_id_foreign")
  invitation Invitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "camp_managers_invitation_id_foreign")

  @@index([campId], map: "camp_managers_camp_id_foreign")
  @@index([userId], map: "camp_managers_user_id_foreign")
  @@index([invitationId], map: "camp_manager_invitation_id_foreign")
  @@map("camp_managers")
}

model Invitation {
  id          String        @id @unique(map: "invitations_id_unique") @default(ulid()) @db.Char(26)
  email       String        @db.VarChar(255)
  campManager CampManager[]

  @@map("camp_manager_invitations")
}

enum RegistrationStatus {
  ACCEPTED
  PENDING
  WAITLISTED
}

model Registration {
  id                String             @id @unique(map: "registrations_id_unique") @default(ulid()) @db.Char(26)
  campId            String             @map("camp_id") @db.Char(26)
  /// ![Record<string, unknown>]
  data              Json               @db.Json
  /// ![Record<string, unknown>]
  customData        Json?              @map("custom_data") @db.Json
  // Computed fields
  firstName         String?            @map("first_name")
  lastName          String?            @map("last_name")
  role              String?
  gender            String?
  dateOfBirth       DateTime?          @map("date_of_birth") @db.Date
  /// ![Array<string>]
  emails            Json?
  street            String?
  city              String?
  zipCode           String?            @map("zip_code")
  country           String?
  newsletterConsent Boolean?           @map("newsletter_consent")
  locale            String             @default("en-US") @db.VarChar(5)
  //
  status            RegistrationStatus @default(PENDING)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime?          @updatedAt @map("updated_at")

  camp       Camp              @relation(fields: [campId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "registrations_camp_id_foreign")
  bed        Bed?
  files      File[]
  deliveries MessageDelivery[]

  @@map("registrations")
}

model Room {
  id        String @id @unique(map: "rooms_id_unique") @default(ulid()) @db.Char(26)
  campId    String @map("camp_id") @db.Char(26)
  /// ![string | Record<string, string>]
  name      Json   @db.Json
  sortOrder Int    @default(999) @map("sort_order")

  camp Camp  @relation(fields: [campId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "rooms_camp_id_foreign")
  beds Bed[]

  @@map("rooms")
}

model Bed {
  id             String  @id @unique @default(ulid()) @db.Char(26)
  roomId         String  @map("room_id") @db.Char(26)
  registrationId String? @unique(map: "beds_registration_id_unique") @map("registration_id") @db.Char(26)

  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "beds_room_id_foreign")
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "beds_registration_id_foreign")

  @@map("beds")
}

model TableTemplate {
  id     String @id @unique(map: "table_templates_id_unique") @default(ulid()) @db.Char(26)
  campId String @map("camp_id") @db.Char(26)
  /// ![Record<string, unknown>]
  data   Json   @db.Json

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "table_templates_camp_id_foreign")

  @@index([campId], map: "table_templates_camp_id_foreign")
  @@map("table_templates")
}

model Token {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id") @db.Char(26)
  token       String    @db.Char(255)
  type        TokenType
  expiresAt   DateTime  @map("expires_at")
  blacklisted Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

enum TokenType {
  ACCESS
  REFRESH
  RESET_PASSWORD
  VERIFY_EMAIL
  RESTRICTED_ACCESS
}

enum UploadStatus {
  PENDING
  READY
}

model File {
  id                  String       @id @unique(map: "files_id_unique") @default(ulid()) @db.Char(26)
  campId              String?      @map("camp_id") @db.Char(26) // Prisma does not support morth
  registrationId      String?      @map("registration_id") @db.Char(26) // Prisma does not support morth
  messageId           String?      @map("message_id") @db.Char(26) // Prisma does not support morth
  messageDeliveryId   String?      @map("message_delivery_id") @db.Char(26) // Prisma does not support morth
  messageTemplateId   String?      @map("message_template_id") @db.Char(26) // Prisma does not support morth
  newsletterMessageId String?      @map("newsletter_message_id") @db.Char(26) // Prisma does not support morth
  name                String
  originalName        String       @map("original_name")
  field               String?
  locale              String?
  type                String
  size                Int
  accessLevel         String?      @map("access_level")
  storageLocation     String       @map("storage_location")
  uploadStatus        UploadStatus @default(READY) @map("upload_status")
  createdAt           DateTime     @default(now()) @map("created_at")

  camp              Camp?              @relation(fields: [campId], references: [id], onDelete: SetNull)
  registration      Registration?      @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  message           Message?           @relation(fields: [messageId], references: [id], onDelete: SetNull)
  messageDelivery   MessageDelivery?   @relation(fields: [messageDeliveryId], references: [id], onDelete: SetNull)
  messageTemplate   MessageTemplate?   @relation(fields: [messageTemplateId], references: [id], onDelete: SetNull)
  newsletterMessage NewsletterMessage? @relation(fields: [newsletterMessageId], references: [id], onDelete: SetNull)

  @@map("files")
}

model Message {
  id           String   @id @unique(map: "message_id_unique") @default(ulid()) @db.Char(26)
  campId       String   @map("camp_id") @db.Char(26)
  sentByUserId String?  @map("sent_by_user_id") @db.Char(26)
  priority     String   @default("normal")
  replyTo      String?  @map("reply_to")
  subject      String   @db.Text
  body         String   @db.LongText
  createdAt    DateTime @default(now()) @map("created_at")

  camp        Camp              @relation(fields: [campId], references: [id], onDelete: Cascade)
  sentBy      User?             @relation(fields: [sentByUserId], references: [id], onDelete: SetNull, map: "messages_sent_by_user_id_foreign")
  deliveries  MessageDelivery[]
  attachments File[]

  @@index([sentByUserId], map: "messages_sent_by_user_id_index")
  @@map("messages")
}

// A single per-recipient rendered email produced from a Message (ad-hoc send)
// or a MessageTemplate (automated event template).
model MessageDelivery {
  id             String   @id @unique(map: "message_delivery_id_unique") @default(ulid()) @db.Char(26)
  templateId     String?  @map("message_template_id") @db.Char(26)
  messageId      String?  @map("message_id") @db.Char(26)
  registrationId String?  @map("registration_id") @db.Char(26)
  to             String?  @db.TinyText
  cc             String?  @db.TinyText
  bcc            String?  @db.TinyText
  replyTo        String?  @map("reply_to")
  subject        String   @db.MediumText
  body           String   @db.MediumText
  priority       String   @default("normal")
  createdAt      DateTime @default(now()) @map("created_at")

  template     MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  message      Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)
  registration Registration?    @relation(fields: [registrationId], references: [id])
  attachments  File[]

  @@map("message_deliveries")
}

// Reusable, automated template keyed by an event (and optional country).
model MessageTemplate {
  id        String    @id @unique(map: "message_template_id_unique") @default(ulid()) @db.Char(26)
  campId    String    @map("camp_id") @db.Char(26)
  country   String?
  event     String
  priority  String    @default("normal")
  replyTo   String?   @map("reply_to")
  subject   String    @db.Text
  body      String    @db.LongText
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  camp        Camp              @relation(fields: [campId], references: [id], onDelete: Cascade)
  deliveries  MessageDelivery[]
  attachments File[]

  @@unique([country, event, campId], map: "message_templates_country_event_camp_id_unique")
  @@map("message_templates")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Job {
  id         String    @id @unique(map: "jobs_id_unique") @default(ulid()) @db.Char(26)
  name       String    @db.VarChar(255)
  queue      String    @db.VarChar(255)
  payload    Json      @db.Json
  status     JobStatus @default(PENDING)
  priority   Int       @default(1) @db.UnsignedTinyInt
  attempts   Int       @default(0)
  error      String?   @db.Text
  runAt      DateTime? @map("run_at") @db.DateTime(3)
  reservedAt DateTime? @map("reserved_at") @db.DateTime(3)
  finishedAt DateTime? @map("finished_at") @db.DateTime(3)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([status, runAt], map: "jobs_status_run_at_index")
  @@map("jobs")
}

model JobRateLimit {
  queue      String   @id @unique(map: "queue_unique") @db.VarChar(255)
  tokens     Float
  refilledAt DateTime @map("refilled_at") @db.DateTime(3)

  @@map("job_rate_limits")
}

model Newsletter {
  id          String    @id @unique(map: "newsletters_id_unique") @default(ulid()) @db.Char(26)
  name        String    @db.VarChar(255)
  description String?   @db.Text
  replyTo     String?   @map("reply_to") @db.Char(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  managers    NewsletterManager[]
  subscribers NewsletterSubscriber[]
  messages    NewsletterMessage[]

  @@map("newsletters")
}

model NewsletterManager {
  id           String @id @unique(map: "newsletter_managers_id_unique") @default(ulid()) @db.Char(26)
  newsletterId String @map("newsletter_id") @db.Char(26)
  userId       String @map("user_id") @db.Char(26)
  role         String @default("OWNER") @db.VarChar(50)

  newsletter Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "newsletter_managers_newsletter_id_foreign")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "newsletter_managers_user_id_foreign")

  @@unique([newsletterId, userId], map: "newsletter_managers_newsletter_id_user_id_unique")
  @@index([newsletterId], map: "newsletter_managers_newsletter_id_index")
  @@index([userId], map: "newsletter_managers_user_id_index")
  @@map("newsletter_managers")
}

model NewsletterSubscriber {
  id               String   @id @unique(map: "newsletter_subscribers_id_unique") @default(ulid()) @db.Char(26)
  newsletterId     String   @map("newsletter_id") @db.Char(26)
  email            String   @db.VarChar(255)
  name             String?  @db.VarChar(255)
  unsubscribeToken String   @unique(map: "newsletter_subscribers_unsubscribe_token_unique") @map("unsubscribe_token") @db.Char(64)
  subscribedAt     DateTime @default(now()) @map("subscribed_at")

  newsletter Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "newsletter_subscribers_newsletter_id_foreign")

  @@unique([newsletterId, email], map: "newsletter_subscribers_newsletter_id_email_unique")
  @@index([newsletterId], map: "newsletter_subscribers_newsletter_id_index")
  @@map("newsletter_subscribers")
}

model NewsletterMessage {
  id             String   @id @unique(map: "newsletter_messages_id_unique") @default(ulid()) @db.Char(26)
  newsletterId   String   @map("newsletter_id") @db.Char(26)
  sentByUserId   String?  @map("sent_by_user_id") @db.Char(26)
  subject        String   @db.VarChar(255)
  body           String   @db.Text
  recipientCount Int      @map("recipient_count")
  sentAt         DateTime @default(now()) @map("sent_at")

  newsletter  Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "newsletter_messages_newsletter_id_foreign")
  sentBy      User?      @relation(fields: [sentByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade, map: "newsletter_messages_sent_by_user_id_foreign")
  attachments File[]

  @@index([newsletterId], map: "newsletter_messages_newsletter_id_index")
  @@map("newsletter_messages")
}

model ProgramEvent {
  id       String  @id @unique(map: "program_event_id_unique") @default(ulid()) @db.Char(26)
  campId   String  @map("camp_id") @db.Char(26) // Prisma does not support morth
  /// ![string | Record<string, string>]
  title    Json
  /// ![string | Record<string, string>]
  details  Json?
  /// ![string | Record<string, string>]
  location Json?
  date     String?
  duration Int?
  time     String?
  color    String? @map("color")
  plan     String  @default("both")
  camp     Camp    @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("program_events")
}

model AuditLog {
  id         String   @id @unique(map: "audit_logs_id_unique") @default(ulid()) @db.Char(26)
  action     String   @db.VarChar(64)
  entityType String   @map("entity_type") @db.VarChar(64)
  entityId   String   @map("entity_id") @db.Char(26)
  campId     String?  @map("camp_id") @db.Char(26)
  actorId    String?  @map("actor_id") @db.Char(26)
  actorIp    String?  @map("actor_ip") @db.VarChar(45)
  /// ![{ changedFields?: Array<string>; changedValues?: Record<string, string | number | boolean | null> }]
  changes    Json?    @db.Json
  createdAt  DateTime @default(now()) @map("created_at")

  camp Camp? @relation(fields: [campId], references: [id], onDelete: SetNull, map: "audit_logs_camp_id_foreign")

  @@index([entityType, entityId], map: "audit_logs_entity_index")
  @@index([campId, createdAt], map: "audit_logs_camp_id_created_at_index")
  @@index([actorId], map: "audit_logs_actor_id_index")
  @@map("audit_logs")
}
