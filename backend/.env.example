# Copy this file to `.env` and fill in the values for your environment.
# NODE_ENV is not set here — it's provided by the npm scripts (see
# package.json: `cross-env NODE_ENV=development|production`).

# Application Configuration
APP_PORT=8000
APP_URL=http://localhost:8000
APP_NAME="Camp Registration Service"
# Primary color used in email templates. Defaults to #338d8e.
#APP_PRIMARY_COLOR=#338d8e
# Sentry DSN for error tracking. Unset disables Sentry.
#SENTRY_DSN=
# Override the default log level (error|warn|info|http|debug).
#LOG_LEVEL=
# Disable IP rate limiting. Opt-in override for e2e tests.
#RATE_LIMIT_DISABLED=false

# Database configuration
DATABASE_URL="mysql://user:password@localhost:3306/database"
SHADOW_DATABASE_URL="mysql://user:password@localhost:3306/shadow_database"

# Secrets
# Generate with `openssl rand -base64 32` (or similar).
JWT_SECRET=
CSRF_SECRET=
TOTP_RECOVERY_CODE_SECRET=

# Auth token expiration
#TOKEN_EXPIRATION_ACCESS=30
#TOKEN_EXPIRATION_REFRESH=30
#TOKEN_EXPIRATION_RESET_PASSWORD=10
#TOKEN_EXPIRATION_VERIFY_EMAIL=10

# Storage
# "disk" (default) or "s3". S3_* below is only required when set to "s3".
#STORAGE_LOCATION=disk
#TMP_DIR=storage/tmp
#UPLOAD_DIR=storage/uploads
#STATIC_DIR=storage/static
#MAX_FILE_SIZE=100000000
# File encryption at rest: `keyId:base64Key[,olderKeyId:base64Key]`, first key
# encrypts new files. Key schema: kYYYYMMDD-NN (e.g. k20260101-01).
# Generate a key with `openssl rand -base64 32`. Unset disables encryption.
#STORAGE_ENCRYPTION_KEYS=
# S3-compatible storage (only used when STORAGE_LOCATION=s3)
#S3_ENDPOINT=
#S3_REGION=
#S3_BUCKET=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_FORCE_PATH_STYLE=true
#S3_OBJECT_PREFIX=

# Queue: "database" (default), "redis" or "memory"
QUEUE_DRIVER=database

# Redis (only required when QUEUE_DRIVER or REALTIME_DRIVER is "redis")
#REDIS_HOST=
#REDIS_USERNAME=default
#REDIS_PORT=6379
#REDIS_PASSWORD=
#REDIS_DB=0

# Realtime event bus driver: "redis" or "memory". Defaults to redis when
# QUEUE_DRIVER is redis (multi-instance deployment), memory otherwise.
#REALTIME_DRIVER=

# SMTP configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=true
#SMTP_USERNAME=
#SMTP_PASSWORD=

# Email configuration
# EMAIL_DRIVER: "smtp" (default) or "noop" (skip sending, e.g. for tests)
#EMAIL_DRIVER=smtp
EMAIL_FROM=noreply@yourapp.com
EMAIL_REPLY_TO=reply-to@yourapp.com
EMAIL_ADMIN=admin@yourapp.com

# Translation
# Auto-translate provider for translated input fields. Unset (default) hides
# the auto-translate feature in the UI. Set to "azure", "deepl" or "google"
# and provide the matching key(s) below to enable it.
#TRANSLATION_DRIVER=
#AZURE_TRANSLATOR_KEY=
#AZURE_TRANSLATOR_REGION=
#AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
#DEEPL_API_KEY=
#DEEPL_API_URL=
#GOOGLE_TRANSLATE_API_KEY=
