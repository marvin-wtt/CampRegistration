{
  "name": "@camp-registration/api",
  "version": "0.0.1",
  "type": "module",
  "description": "An API for camp registrations",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf ./build/ && rimraf ./node_modules/",
    "build": "prisma generate && tsc && tsc-alias && cp ./src/entry.cjs ./build/ && npm run build:views",
    "build:views": "mkdirp ./build/views/emails/ && mjml src/views/emails/**/*.mjml -o ./build/views/emails/",
    "data-miration:message-templates": "tsx prisma/migrations/20260121175357_update_message_templates_add_country_column/migration.ts",
    "data-miration:registration-status": "tsx prisma/migrations/20260124022616_update_registrations_replace_waitinglist_with_status/migration.ts",
    "migrate": "npm run db:migrate",
    "db:migrate": "prisma migrate deploy",
    "db:reset": "npx prisma db push --force-reset --accept-data-loss",
    "db:truncate": "tsx prisma/scripts/truncate.ts",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test": "npm run test:int",
    "test:unit": "vitest -c ./vitest.config.unit.ts",
    "test:unit:ui": "vitest -c ./vitest.config.unit.ts --ui",
    "test:int": "vitest -c ./vitest.config.integration.ts",
    "test:int:ui": "./scripts/run-integration.sh --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"**/*.{js,ts,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,ts,md,json}\" --ignore-path .gitignore",
    "dev": "npm run dev:views && npm run dev:serve",
    "dev:views": "mjml -w src/views/emails/**/*.mjml -o ./build/views/emails/",
    "dev:serve": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "production": "cross-env NODE_ENV=production node build/entry.cjs"
  },
  "keywords": [],
  "author": "marvin-wtt <31454580+marvin-wtt@users.noreply.github.com>",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marvin-wtt/CampRegistration",
    "directory": "backend"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "imports": {
    "#app/*": "./src/app/*.js",
    "#assets/*": "./src/assets/*.js",
    "#config/*": "./src/config/*.js",
    "#core/*": "./src/core/*.js",
    "#guards/*": "./src/guards/*.js",
    "#i18n/*": "./src/i18n/*.js",
    "#jobs/*": "./src/jobs/*.js",
    "#middlewares/*": "./src/middlewares/*.js",
    "#routes/*": "./src/routes/*.js",
    "#utils/*": "./src/utils/*.js",
    "#views/*": "./src/views/*.js",
    "#types/*": "./src/types/*.js",
    "#generated/*": "./src/generated/*.js"
  },
  "dependencies": {
    "@camp-registration/common": "*",
    "@camp-registration/web": "*",
    "@candoimage/prisma-extension-soft-delete": "^2.1.2",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "compression": "^1.8.1",
    "content-disposition": "^1.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "countries-list": "^3.3.0",
    "country-flag-icons": "^1.6.15",
    "croner": "^10.0.1",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.7",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.1",
    "fs-extra": "^11.3.4",
    "helmet": "^8.1.0",
    "html-to-text": "^9.0.5",
    "http-status": "^2.1.0",
    "i18next": "^26.0.3",
    "inversify": "^8.1.0",
    "moment": "^2.30.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "otpauth": "^9.5.0",
    "package-directory": "^8.2.0",
    "passport": "^0.7.0",
    "passport-anonymous": "^1.0.1",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "survey-core": "2.5.4",
    "ulidx": "^2.4.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^9.9.0",
    "@types/async-lock": "^1.4.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/content-disposition": "^0.5.9",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/html-to-text": "^9.0.4",
    "@types/mjml": "^4.7.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.17",
    "@types/passport-anonymous": "^1.0.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-security": "^4.0.0",
    "html-entities": "^2.6.0",
    "mjml": "^5.0.0-alpha.4",
    "mkdirp": "^3.0.1",
    "nodemailer-mock": "^2.0.10",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "prisma-json-types-generator": "^4.1.1",
    "smtp-tester": "^2.1.0",
    "supertest": "^7.1.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "vitest-mock-extended": "^3.1.0"
  }
}
