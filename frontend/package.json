{
  "name": "@camp-registration/web",
  "version": "0.0.1",
  "productName": "Camp Registrations",
  "description": "Manage camp registrations",
  "author": "marvin-wtt <31454580+marvin-wtt@users.noreply.github.com>",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/marvin-wtt/CampRegistration",
    "directory": "frontend"
  },
  "scripts": {
    "postinstall": "quasar prepare",
    "clean": "quasar clean && rimraf ./node_modules/",
    "dev": "quasar dev",
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\" && npm run i18n:check",
    "i18n:check": "node scripts/i18n/check.mjs",
    "i18n:add-locale": "node scripts/i18n/add-locale.mjs",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "build": "quasar build",
    "test": "npm run test:unit:ci",
    "test:unit:ui": "vitest --ui",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run"
  },
  "dependencies": {
