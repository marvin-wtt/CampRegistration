    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "apexcharts": "^5.15.0",
    "axios": "^1.17.0",
    "dompurify": "^3.4.11",
